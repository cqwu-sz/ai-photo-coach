  {
    "id": "depth_foreground_frame",
    "category": "depth",
    "name_zh": "前景框",
    "summary": "用近处的窗框、树枝、人群剪影把主体『框』起来，瞬间出现纵深感",
    "axes": ["depth", "composition", "subject_fit"],
    "scene_modes": ["portrait", "documentary", "scenery"],
    "person_count_range": [1, 3],
    "priority": 4,
    "when_to_use": ["杂乱街景", "建筑内景", "想增加私密感"],
    "evidence": "natural framing 是构图老技；前景虚化让框成为『暗角』，主体被引导",
    "watch_out": "前景遮挡不要超过 25% 画面；不要遮住关键叙事元素",
    "counter_example": "全景风光 + 简洁背景不需要前景框",
    "tags": ["前景框", "Framing", "纵深"],
    "citations": [
      { "source": "Michael Freeman《The Photographer's Eye》", "chapter": "Frames" }
    ],
    "embedding": null
