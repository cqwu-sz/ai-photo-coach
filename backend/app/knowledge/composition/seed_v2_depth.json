  {
    "id": "depth_negative_space",
    "category": "depth",
    "name_zh": "负空间",
    "summary": "主体周围留大块空白（天空 / 墙 / 水面），让主体呼吸；情绪与极简感的核心",
    "axes": ["depth", "composition", "theme"],
    "scene_modes": ["portrait", "scenery", "light_shadow"],
    "person_count_range": [0, 3],
    "priority": 4,
    "when_to_use": ["孤独 / 等待 / 告别 主题", "极简风景", "禅意构图"],
    "evidence": "负空间≥60% 时画面感强烈；东方水墨『计白当黑』同理",
    "watch_out": "负空间不能是杂乱纹理（云乱、墙脏），要均匀；主体太小就完全消失",
    "counter_example": "热闹叙事（合影、节日）反而要饱满",
    "tags": ["负空间", "留白", "极简"],
    "citations": [
      { "source": "Bryan Peterson《Learning to See Creatively》", "chapter": "Negative Space" },
      { "source": "中国画论", "chapter": "计白当黑" }
    ],
