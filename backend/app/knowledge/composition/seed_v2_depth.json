  {
    "id": "depth_compression_long_lens",
    "category": "depth",
    "name_zh": "长焦压缩感",
    "summary": "85mm 以上长焦把多层背景拉近，营造『密集排列』的视觉重量",
    "axes": ["depth", "composition"],
    "scene_modes": ["portrait", "documentary", "scenery"],
    "person_count_range": [1, 3],
    "priority": 4,
    "when_to_use": ["人在繁华街景", "山叠山", "城市天际线"],
    "evidence": "焦段越长，远近物体的视角差越小，肉眼会觉得『近大远大』；铁路远山压缩是经典示例",
    "watch_out": "长焦虚化深，要等主体停稳；手持需快门≥ 1/焦段",
    "counter_example": "想表达环境关系/广角张力时不要用长焦",
    "tags": ["长焦", "压缩", "重量感"],
    "citations": [
      { "source": "Bryan Peterson《Understanding Composition》", "chapter": "Lens Choice" }
    ],
