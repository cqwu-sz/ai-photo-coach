  {
    "id": "depth_atmospheric_perspective",
    "category": "depth",
    "name_zh": "空气透视",
    "summary": "远山远景因雾气、灰度、低饱和而显得『后退』，是风光片打造纵深的天然滤镜",
    "axes": ["depth", "color"],
    "scene_modes": ["scenery", "documentary"],
    "person_count_range": [0, 3],
    "priority": 4,
    "when_to_use": ["山景", "晨雾", "日出日落远景"],
    "evidence": "达·芬奇《绘画论》最早提出的空气透视：远处更冷、更淡、对比更低；摄影继承同样规律",
    "watch_out": "雾太重会让远景全糊一片，找『还有可读形状的雾度』；后期不要把远景拉回高对比",
    "counter_example": "通透晴空时空气透视弱，要靠其他纵深手段",
    "tags": ["空气透视", "雾", "远景"],
    "citations": [
      { "source": "Leonardo da Vinci《Treatise on Painting》", "chapter": "Aerial Perspective" }
    ],
