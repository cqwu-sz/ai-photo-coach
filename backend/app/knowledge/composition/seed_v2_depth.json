  {
    "id": "depth_leading_line_to_subject",
    "category": "depth",
    "name_zh": "引导线纵深",
    "summary": "道路 / 河流 / 栏杆从画面边缘延伸到主体，把视线和空间一起带过去",
    "axes": ["depth", "composition"],
    "scene_modes": ["scenery", "documentary", "portrait"],
    "person_count_range": [0, 3],
    "priority": 4,
    "when_to_use": ["乡间小路", "海堤", "走廊"],
    "evidence": "引导线既建立视觉路径又制造透视纵深；S 形最自然，直线最强势",
    "watch_out": "引导线不能从主体身上『穿』过去；线条要消失在画面外或主体身上",
    "counter_example": "杂乱多线交叉的画面会变成混乱网格，反而失去引导",
    "tags": ["引导线", "透视", "纵深"],
    "citations": [
      { "source": "Michael Freeman《The Photographer's Eye》", "chapter": "Leading Lines" }
    ],
