  {
    "id": "comp_open_vs_closed",
    "category": "composition",
    "name_zh": "开放/封闭式构图",
    "summary": "封闭：所有视觉元素都向内；开放：主体或动势指向画框外",
    "axes": ["composition", "theme"],
    "scene_modes": ["portrait", "full_body", "documentary"],
    "person_count_range": [1, 4],
    "priority": 3,
    "when_to_use": ["叙事人文（开放）", "肖像永恒感（封闭）", "环境人像"],
    "evidence": "开放式让画面成为更大故事的一部分；封闭式让画面成为完整的一刻",
    "watch_out": "开放式需要主体视线/动势真的指向画外，否则只是『主体被切到了』",
    "counter_example": "证件照需要封闭，开放会被认为构图错误",
    "tags": ["叙事", "肖像", "故事"],
    "citations": [
      { "source": "Michael Freeman, The Photographer's Eye", "chapter": "Ch.7 Frame and Edge" }
