[
  {
    "id": "comp_rule_of_thirds",
    "category": "composition",
    "name_zh": "三分法",
    "summary": "把画面横竖各 1/3 切成 9 格，主体放交叉点或沿三分线",
    "axes": ["composition", "subject_fit"],
    "scene_modes": ["portrait", "closeup", "full_body", "documentary", "scenery", "light_shadow"],
    "person_count_range": [0, 4],
    "priority": 5,
    "when_to_use": ["人像半身/全身", "风光带主体", "环境人像"],
    "evidence": "把视觉重心从正中心移开，能让画面产生流动感与呼吸空间；眼睛偏离中心也更接近自然观看习惯",
    "watch_out": "背景已左右对称（建筑正立面、对称湖景）时强行三分会破坏稳定感",
    "counter_example": "拍证件照、国宝建筑正面、节日合影 — 这些主题就是要居中",
    "tags": ["对称感弱", "动态感强", "适配 16:9"],
    "citations": [
      { "source": "Michael Freeman, The Photographer's Eye (Definitive Ed)", "chapter": "Ch.3 Dividing the Frame" },
      { "source": "宁思潇潇《新摄影笔记》", "chapter": "Ch.4 构图基础" }
    ],
    "embedding": null
  },
  {
    "id": "comp_leading_line",
    "category": "composition",
    "name_zh": "引导线",
    "summary": "用画面里的线条（路、栏杆、河流、墙缝）把视线牵向主体或远方",
    "axes": ["composition"],
    "scene_modes": ["portrait", "full_body", "documentary", "scenery", "light_shadow"],
    "person_count_range": [0, 4],
    "priority": 5,
    "when_to_use": ["有路或栏杆的环境人像", "风景纵深表达", "街拍纪实"],
    "evidence": "线条天然牵引眼睛，被引导的视觉路径让构图获得方向性，避免观者无从下手",
    "watch_out": "引导线尽头若是空白或杂物会反向破功，必须确认终点是主体或值得看的元素",
    "counter_example": "正午顶光下没有阴影线、又没有结构线时硬找『引导线』反而会让画面变碎",
    "tags": ["纵深", "动势", "节奏"],
    "citations": [
      { "source": "Michael Freeman, The Photographer's Eye", "chapter": "Ch.4 Lines and Curves" },
      { "source": "顾荣军《非常摄影手记》", "chapter": "解密篇 · 引导线构图" }
    ],
    "embedding": null
  },
  {
    "id": "comp_symmetry",
    "category": "composition",
    "name_zh": "对称构图",
    "summary": "左右或上下对称的轴线把画面对折后能基本重叠",
    "axes": ["composition"],
    "scene_modes": ["portrait", "documentary", "scenery", "light_shadow"],
    "person_count_range": [0, 4],
    "priority": 4,
    "when_to_use": ["建筑正面", "倒影", "对称室内场景"],
    "evidence": "对称制造稳定与庄重感，是表达秩序、仪式感的最快语言",
    "watch_out": "对称时主体姿态也容易僵化，让模特微侧身或一只手破对称会更鲜活",
    "counter_example": "纪实场景里强求对称会牺牲决定性瞬间",
    "tags": ["仪式感", "稳定", "建筑友好"],
    "citations": [
      { "source": "Michael Freeman, The Photographer's Eye", "chapter": "Ch.5 Symmetry and Balance" }
    ],
    "embedding": null
  },
  {
    "id": "comp_frame_within_frame",
    "category": "composition",
    "name_zh": "框中框",
    "summary": "用门、窗、拱、树枝当『画面里的画框』把主体框起来",
    "axes": ["composition", "subject_fit"],
    "scene_modes": ["portrait", "closeup", "full_body", "documentary", "scenery"],
    "person_count_range": [0, 3],
    "priority": 4,
    "when_to_use": ["建筑街拍", "环境人像", "室内人像"],
    "evidence": "二次框定让观看带有窥视的故事感，同时把杂乱环境圈在框外做减法",
    "watch_out": "框过厚或太抢眼会反客为主，主体应仍占据视觉重量的 60% 以上",
    "counter_example": "光影模式下，画框里抢眼的强光柱会和主体打架",
    "tags": ["故事感", "做减法", "层次"],
    "citations": [
      { "source": "Michael Freeman, The Photographer's Eye", "chapter": "Ch.6 Framing" },
      { "source": "顾荣军《非常摄影手记》", "chapter": "实战篇 · 框中框" }
    ],
    "embedding": null
  },
  {
    "id": "comp_negative_space",
    "category": "composition",
    "name_zh": "留白",
    "summary": "在主体周围留出大面积纯净区域（天空、墙面、雾、水）",
    "axes": ["composition", "subject_fit", "theme"],
    "scene_modes": ["portrait", "scenery", "light_shadow"],
    "person_count_range": [0, 2],
    "priority": 5,
    "when_to_use": ["孤独主题", "极简风", "海边风光", "晨雾人像"],
    "evidence": "留白让主体被『看见』，并赋予情绪呼吸；东方画论里的『计白当黑』即此",
    "watch_out": "留白超过 75% 时主体会被压扁失重，需要靠位置（三分线交点）锚回来",
    "counter_example": "纪实人文要的是信息密度，过度留白会显得空洞",
    "tags": ["极简", "情绪", "主体突出"],
    "citations": [
      { "source": "宁思潇潇《新摄影笔记》", "chapter": "Ch.4 留白与节奏" },
      { "source": "Michael Freeman, The Photographer's Eye", "chapter": "Ch.7 Negative Space" }
    ],
    "embedding": null
  },
  {
    "id": "comp_diagonal",
    "category": "composition",
    "name_zh": "对角线构图",
    "summary": "主体或主线沿画面对角线走向，左下到右上更稳，右下到左上更紧张",
    "axes": ["composition"],
    "scene_modes": ["portrait", "full_body", "documentary", "scenery", "light_shadow"],
    "person_count_range": [0, 4],
    "priority": 4,
    "when_to_use": ["楼梯", "桥栏", "运动主体", "倾斜光柱"],
    "evidence": "对角线打破水平的稳定感，制造动势与张力；西方观看习惯下两条对角线情绪不同",
    "watch_out": "倾角过大（接近 45°）易让人觉得画面歪掉而非动感，控制在 20-35°",
    "counter_example": "证件照、商业产品图等需要稳定时不可用",
    "tags": ["动势", "张力", "节奏"],
    "citations": [
      { "source": "Michael Freeman, The Photographer's Eye", "chapter": "Ch.4 Diagonals" }
    ],
    "embedding": null
  },
  {
    "id": "comp_golden_ratio",
    "category": "composition",
    "name_zh": "黄金比",
    "summary": "把画面按 1:1.618 分割，主体放在分割点（比三分线更靠中）",
    "axes": ["composition"],
    "scene_modes": ["portrait", "scenery"],
    "person_count_range": [0, 2],
    "priority": 3,
    "when_to_use": ["静物", "人像半身", "古典风光"],
    "evidence": "黄金比例是比三分法更精细的视觉舒适比例，文艺复兴绘画与古典摄影常用",
    "watch_out": "现代手机取景器一般只有三分网格，肉眼估比例较难，可以拍后裁",
    "counter_example": "节奏快的纪实抓拍没时间精算比例，按三分法已足够",
    "tags": ["古典", "精细", "视觉舒适"],
    "citations": [
      { "source": "Michael Freeman, The Photographer's Eye", "chapter": "Ch.3 Golden Ratio" }
    ],
    "embedding": null
  },
  {
    "id": "comp_centered",
    "category": "composition",
    "name_zh": "居中构图",
    "summary": "主体放在画面正中，左右元素对称或对称式平衡",
    "axes": ["composition", "theme"],
    "scene_modes": ["portrait", "closeup", "documentary", "scenery", "light_shadow"],
    "person_count_range": [0, 2],
    "priority": 4,
    "when_to_use": ["仪式感", "证件照", "国宝级建筑正面", "对称湖景倒影"],
    "evidence": "正中放置传达庄重、坚定、永恒的语义；剪影构图也常用此",
    "watch_out": "若主体本身缺戏剧性（普通人像、随手快照），居中会显得呆板",
    "counter_example": "环境人像应让主体偏离中心，给环境更多发言权",
    "tags": ["稳定", "庄重", "对称"],
    "citations": [
      { "source": "顾荣军《非常摄影手记》", "chapter": "解密篇 · 居中构图" }
    ],
    "embedding": null
  },
  {
    "id": "comp_layers_three",
    "category": "composition",
    "name_zh": "前-中-后三层",
    "summary": "前景、中景、远景三段式分布，眼睛能从近到远依次扫过",
    "axes": ["composition", "depth"],
    "scene_modes": ["full_body", "documentary", "scenery", "light_shadow"],
    "person_count_range": [0, 4],
    "priority": 5,
    "when_to_use": ["山水风光", "环境人像", "纪实街拍"],
    "evidence": "三层构图让二维画面获得纵深与故事感；前景给观者『进入』画面的把手",
    "watch_out": "三层各自要有可识别的元素，否则只是『近一点远一点』，没层次",
    "counter_example": "特写主体本身没有空间可分层，强求三层会切碎主体",
    "tags": ["纵深", "故事感", "风光必修"],
    "citations": [
      { "source": "Michael Freeman, The Photographer's Eye", "chapter": "Ch.8 Depth" },
      { "source": "宁思潇潇《新摄影笔记》", "chapter": "Ch.4 层次" }
    ],
    "embedding": null
