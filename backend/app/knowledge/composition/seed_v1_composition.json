  {
    "id": "comp_high_angle",
    "category": "composition",
    "name_zh": "高位俯拍",
    "summary": "镜头比主体高，俯角拍摄（站着拍坐姿主体或拍桌面/地面）",
    "axes": ["composition", "subject_fit", "theme"],
    "scene_modes": ["portrait", "closeup", "full_body", "documentary", "scenery"],
    "person_count_range": [0, 4],
    "priority": 4,
    "when_to_use": ["特写脸部", "桌面美食", "幼龄主体", "弱化身材时"],
    "evidence": "俯角让主体被『罩住』，传达温柔、保护或观察感，特写脸时显眼大",
    "watch_out": "俯角过大显矮，且会强调头顶发型问题；女性人像 5-15° 内最优",
    "counter_example": "想表达主体的力量感（运动员、舞者）就别俯拍",
    "tags": ["温柔", "特写", "美食"],
    "citations": [
      { "source": "巴内克《人像摄影经典教程》", "chapter": "Ch.3 视角" }
    ],
