  {
    "id": "comp_low_angle",
    "category": "composition",
    "name_zh": "低位仰拍",
    "summary": "把镜头放低，仰角拍摄主体（地面高度或膝盖高度）",
    "axes": ["composition", "subject_fit", "theme"],
    "scene_modes": ["portrait", "full_body", "documentary"],
    "person_count_range": [1, 4],
    "priority": 4,
    "when_to_use": ["显腿长", "仪式感人像", "运动主体", "孩子主角时"],
    "evidence": "仰角天然显高显瘦显有气场，模特身材比例从 1:7 优化到 1:8 以上",
    "watch_out": "仰角太大会出现强透视变形（鼻子大脸小），控制在 15-25°内",
    "counter_example": "拍主体在玩手机或低头沉思的安静瞬间，仰角会让神态变成挑衅",
    "tags": ["显腿长", "气场", "运动"],
    "citations": [
