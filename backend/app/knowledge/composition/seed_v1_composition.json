  {
    "id": "comp_rhythm_repeat",
    "category": "composition",
    "name_zh": "几何重复",
    "summary": "用画面里反复出现的几何形（柱子、窗格、瓷砖）建立节奏",
    "axes": ["composition"],
    "scene_modes": ["documentary", "scenery", "light_shadow"],
    "person_count_range": [0, 2],
    "priority": 3,
    "when_to_use": ["建筑街拍", "现代主义场景", "工业空间"],
    "evidence": "重复形状让眼睛获得节奏感，是现代主义摄影的母题；打破节奏的元素自动成为主体",
    "watch_out": "纯粹的几何重复缺乏情感，必须夹一个『破节奏』的人或物作为主角",
    "counter_example": "糖水人像、孩童写真不需要冷峻的节奏",
    "tags": ["节奏", "现代", "建筑"],
    "citations": [
      { "source": "Michael Freeman, The Photographer's Eye", "chapter": "Ch.6 Rhythm" }
