# Copy this file to .env and fill in real values.
# Mock mode lets you run the API end-to-end without a real Gemini key.

APP_ENV=local
APP_PORT=8000
LOG_LEVEL=INFO

# Set MOCK_MODE=true to skip Gemini calls and return canned responses (good for iOS dev)
MOCK_MODE=true

# Required when MOCK_MODE=false
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_HIGH=gemini-2.5-pro

# Knowledge base paths (relative to backend/)
KB_POSES_DIR=app/knowledge/poses
KB_CAMERA_DIR=app/knowledge/camera_settings
KB_COMPOSITION_DIR=app/knowledge/composition

# Limits
MAX_FRAMES=16
MAX_FRAME_BYTES=2097152
MAX_REFERENCE_THUMBS=8
