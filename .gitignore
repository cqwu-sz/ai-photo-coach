# --- Editor / IDE / agent caches ---------------------------------------------
.copilot/
.cursor/rules/
.cursor/plans/
.playwright-mcp/
.idea/
.vscode/
*.swp

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.*
!.env.example
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# --- Node / web tooling ------------------------------------------------------
node_modules/
npm-debug.log*

# --- macOS / Windows housekeeping --------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- App runtime data (sqlite + caches; never commit user data) --------------
backend/data/*.db
backend/data/*.db-journal
backend/data/*.db-wal
backend/data/*.db-shm
backend/data/recon3d_models/
backend/data/attested_devices.db
backend/data/users.db
backend/data/shot_results.db
backend/data/recon3d_jobs.db
backend/data/poi_kb.db

# --- Apple Root CAs ARE committed (small + reproducible) but secret keys are NOT
backend/app/data/AuthKey_*.p8
backend/secrets/

# --- Xcode / iOS -------------------------------------------------------------
*.xcuserstate
xcuserdata/
DerivedData/
build/
*.ipa
*.dSYM.zip

# --- Generated artefacts -----------------------------------------------------
docs/preview/_generated/
web/.tmp/

# --- Large ML model weights (use Git LFS or fetch at deploy time) ------------
# Both depth models are downloaded by web/models/README.md instructions.
web/models/*.onnx
web/models/*.pt
web/models/*.bin
web/models/*.safetensors

# --- 3D avatar / animation glb assets (host on CDN; see web/avatars/README) --
web/avatars/preset/*.glb
web/avatars/animations/*.glb
web/avatars/base/*.glb

# --- Tripo3D generation logs (intermediate artefacts) ------------------------
scripts/_tripo_logs/
/.git-commit-msg.txt
