/*
  Localizable.strings (zh-Hans)
  Baseline Chinese strings for PostProcessKnowledge. Add new keys here
  AND in en.lproj/Localizable.strings — the matching English entry can
  start as a literal Chinese string and be translated later; missing
  keys fall back to the key itself (which is also Chinese), so the app
  never shows a raw key to the user.
*/

// MARK: - PostProcessKnowledge / preset explanations
"postproc.preset.original"      = "不做任何调色，保留你拍到的原始色彩。";
"postproc.preset.cleanBright"   = "轻微提亮 + 微抬对比。适合本身光线就漂亮、想让颜色干净通透的场景。";
"postproc.preset.filmWarm"      = "暖色偏移 + 略低对比。让暖光更暖、肤色更舒服，常用于黄昏 / 室内暖光 / 木质场景。";
"postproc.preset.streetCool"    = "冷色偏移 + 阴影压一点。模仿胶片冷调，适合阴天街拍 / 海边 / 蓝调时刻。";
"postproc.preset.bw"            = "去色 + 局部 S 曲线提对比。当光影本身够戏剧时，去掉颜色反而更聚焦。";
"postproc.preset.japanCrisp"    = "提亮阴影 + 降饱和 + 加一点冷调。日系小清新的核心：低对比 + 高亮度 + 微冷白。";
"postproc.preset.cinematic"     = "压一点高光 + 抬一点阴影 + 加暖色饱和。电影感的本质是宽容度 + 色调统一。";
"postproc.preset.retroFade"     = "提亮纯黑 + 压住纯白 + 降饱和。胶卷褪色感，适合复古 / 慵懒午后。";
"postproc.preset.hkVibe"        = "强对比 + 高饱和 + 偏品红蓝。港风霓虹必备，但夜景别加太重，会糊。";
"postproc.preset.beauty"        = "针对人像做柔肤 + 局部提亮 + 眼神光，保留毛孔质感。";

// MARK: - PostProcessKnowledge / LUT explanations
"postproc.lut.natural"          = "中性查找表，仅做轻微对比与饱和度修正。";
"postproc.lut.film_warm"        = "暖色胶片曲线，模拟 Portra / Gold 系胶卷的偏色。";
"postproc.lut.film_cool"        = "冷色胶片曲线，模拟 Cinestill / Ektar 阴天的偏色。";
"postproc.lut.mono"             = "黑白响应曲线，按 BT.709 亮度加 S 形对比。";
"postproc.lut.hk_neon"          = "推高对比、加强品红/青色分离，做出霓虹海报感。";
"postproc.lut.japanese_clean"   = "抬阴影、降饱和、轻微冷调，日系小清新基础调。";
"postproc.lut.golden_glow"      = "高光偏琥珀，中间调加暖，模拟金色时刻。";
"postproc.lut.moody_fade"       = "黑色不到 0、白色不到 1 的褪色曲线 + 低饱和。";
"postproc.lut.custom"           = "自定义 LUT。";
